import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import os
from scipy.stats import nct

# --- CONFIGURATION ---
base_path = 'Code/Results'
data_type = 'Headline' 
horizons = [3, 6, 9, 12]
rolling_window = 12 

# DEFINE THE 3 MODELS YOU WANT TO COMPARE
# These should match the start of your filenames (e.g., 'Benchmark_ARGARCH', 'bvar_minnesota', 'qrf_default')
models_to_plot = ['Benchmark_ARGARCH', 'bvar_minnesota', 'QRF_default'] 

data_dict = {}

# --- DYNAMIC LOADING LOOP ---
print("Scanning folders...")
for root, dirs, files in os.walk(base_path):
    for file in files:
        if file.endswith('.csv') and data_type in file:
            h_found = None
            for h in horizons:
                if f"_{h}m" in file:
                    h_found = h
                    break
            
            if h_found is not None:
                # This identifies the model name by removing the suffix
                model_name = file.replace(f'_{data_type}_{h_found}m.csv', '')
                
                file_path = os.path.join(root, file)
                try:
                    df = pd.read_csv(file_path, index_col='Date', parse_dates=True)
                    if model_name not in data_dict:
                        data_dict[model_name] = {}
                    data_dict[model_name][h_found] = df
                except Exception as e:
                    print(f"Error loading {file}: {e}")

print(f"Loaded models: {list(data_dict.keys())}")

# --- 1. PIT CALIBRATION (4x3 Grid) ---
# Rows = Horizons, Columns = the 3 Models
fig, axes = plt.subplots(nrows=4, ncols=3, figsize=(15, 18), sharex=True, sharey=True)

for i, h in enumerate(horizons):
    for j, model in enumerate(models_to_plot):
        ax = axes[i, j]
        if model in data_dict and h in data_dict[model]:
            df = data_dict[model][h]
            pit_sorted = np.sort(df['PIT'].dropna())
            n = len(pit_sorted)
            y_vals = np.arange(1, n + 1) / n
            
            ax.plot(pit_sorted, y_vals, color='black', label='Empirical CDF')
            ax.plot([0, 1], [0, 1], color='red', linestyle='--', alpha=0.7)
            
            # 95% Confidence Bands
            ks_critical = 1.36 / np.sqrt(n)
            ax.fill_between(np.linspace(0, 1, n), 
                            np.clip(np.linspace(0, 1, n) - ks_critical, 0, 1),
                            np.clip(np.linspace(0, 1, n) + ks_critical, 0, 1),
                            color='gray', alpha=0.1)

        if i == 0: ax.set_title(f'MODEL: {model}', fontweight='bold')
        if j == 0: ax.set_ylabel(f'Horizon: {h}m\nCumulative Prob', fontweight='bold')
        ax.grid(True, alpha=0.3)

plt.tight_layout(rect=[0, 0.03, 1, 0.95])
fig.suptitle(f'PIT Calibration Comparison ({data_type})', fontsize=16)
plt.show()

# --- 2. ROLLING CRPS COMPARISON (2x2 Grid) ---
# One subplot per horizon, all 3 models as lines inside
fig, axes = plt.subplots(nrows=2, ncols=2, figsize=(14, 10))
axes = axes.flatten()

colors = {models_to_plot[0]: 'red', models_to_plot[1]: 'black', models_to_plot[2]: 'blue'}

for i, h in enumerate(horizons):
    ax = axes[i]
    for model in models_to_plot:
        if model in data_dict and h in data_dict[model]:
            df = data_dict[model][h]
            rolling_crps = df['Parametric_CRPS'].rolling(window=rolling_window).mean()
            ax.plot(df.index, rolling_crps, label=model, color=colors.get(model, 'gray'), linewidth=2)
    
    ax.set_title(f'Forecast Horizon: {h} Months', fontsize=12, fontweight='bold')
    ax.set_ylabel('Rolling CRPS')
    ax.grid(True, alpha=0.3)
    if i == 0: ax.legend()

fig.suptitle(f'Predictive Performance (Rolling {rolling_window}-Period CRPS)', fontsize=16)
plt.tight_layout()
plt.show()

# --- 3. SUMMARY BAR CHART ---
summary_data = []
for model in models_to_plot:
    for h in horizons:
        if model in data_dict and h in data_dict[model]:
            avg_score = data_dict[model][h]['Parametric_CRPS'].mean()
            summary_data.append({'Model': model, 'Horizon': f'{h}m', 'Avg_CRPS': avg_score})

df_summary = pd.DataFrame(summary_data)
if not df_summary.empty:
    plt.figure(figsize=(10, 6))
    sns.barplot(data=df_summary, x='Horizon', y='Avg_CRPS', hue='Model', palette='viridis')
    plt.title('Summary Performance: Average CRPS per Model and Horizon')
    plt.ylabel('Mean CRPS (Lower is Better)')
    plt.show()

# --- 4. SKEW-T DENSITY COMPARISON ---
def plot_comparative_skew_t(target_date, horizon):
    plt.figure(figsize=(10, 6))
    actual_value = None
    
    for model in models_to_plot:
        if model in data_dict and horizon in data_dict[model]:
            df = data_dict[model][horizon]
            if target_date in df.index:
                row = df.loc[target_date]
                actual_value = row['Actual']
                
                # Plot Skew-T PDF using NCT
                x = np.linspace(row['loc_skewt'] - 4*row['scale_skewt'], row['loc_skewt'] + 4*row['scale_skewt'], 500)
                pdf = nct.pdf(x, row['df_skewt'], row['nc_skewt'], loc=row['loc_skewt'], scale=row['scale_skewt'])
                plt.plot(x, pdf, lw=2.5, label=model)
                plt.fill_between(x, pdf, alpha=0.1)
    
    if actual_value is not None:
        plt.axvline(actual_value, color='black', linestyle='--', label=f'Actual: {actual_value:.2f}')

    plt.title(f'Predictive Density Comparison: {target_date.date()} ({horizon}m Horizon)')
    plt.legend()
    plt.show()

# Example usage for the last available date
if models_to_plot[0] in data_dict:
    last_date = data_dict[models_to_plot[0]][3].index[-1]
    plot_comparative_skew_t(last_date, horizon=3)

