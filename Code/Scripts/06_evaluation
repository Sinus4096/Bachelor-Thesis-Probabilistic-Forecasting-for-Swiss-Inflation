#what to compare
data_type= "Headline"   #plot core or headline in comparison
horizons = [3, 6, 9, 12]     #comparison at all horizons ahead
rolling_window =36   #36= ca 3 years for monthly data
crps_col = "Parametric_CRPS"    # or "Empirical_CRPS"

# EXACTLY 3 models (used as columns in grids)
# Matching rule: model key must appear in filename (case-insensitive, non-alnum ignored)
models_compare= ["Benchmark_ARGARCH", "bvar_independent_niw_hierarchical","QRF_Default"]

# If you want to restrict to specific subfolders under Results, set to [] to scan everything.
results_subfolder: List[str] = []


# ============================================================
